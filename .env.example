# ─── Telegram API (احصل عليها من my.telegram.org) ───────────────────────────
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# ─── Database (Railway يوفر هذا تلقائياً عند إضافة PostgreSQL) ──────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# أو لـ SQLite محلي (للتطوير فقط):
# DATABASE_URL=sqlite:///./system.db

# ─── AI Keys (اختر واحداً على الأقل) ───────────────────────────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# النموذج المفضل
PREFERRED_LLM=gemini/gemini-1.5-flash

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
SECRET_KEY=change-this-to-random-string

# ─── Telegram Stealth Settings ───────────────────────────────────────────────
MIN_DELAY_MINUTES=3
MAX_DELAY_MINUTES=15
DELETION_CHECK_SEC=120

# ─── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
