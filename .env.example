# انسخ هذا الملف إلى .env وعدّل القيم

# ─── قاعدة البيانات ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./system.db
# للتبديل إلى PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/dbname

# ─── تيليجرام ────────────────────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here

# ─── الذكاء الاصطناعي (أدخل مفتاحاً واحداً على الأقل) ──────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
PREFERRED_LLM=gpt-4o-mini

# ─── الأمان ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string

# ─── الخادم ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ─── استراتيجية التخفي ───────────────────────────────────────────────────────
MIN_DELAY_MINUTES=3
MAX_DELAY_MINUTES=15
DELETION_CHECK_SEC=120
